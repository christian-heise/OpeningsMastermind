    "Sign in with Lichess": {
      "comment": "A button that signs in the user with Lichess.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit Lichess anmelden"
          }
        }
      }
    },
    "Sign in with Lichess to see opening statistics.": {
      "comment": "A description of the feature that requires Lichess",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Melde dich mit Lichess an, um Eröffnungsstatistiken zu sehen."
          }
        }
      }
    },
    "Sign in with your Lichess account to use the opening explorer (Lichess now requires sign-in for it) and to import studies from your account. Your blitz rating is also used to filter explorer moves to better match your level.": {
      "comment": "Footer for the settings view.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Melde dich mit deinem Lichess-Konto an, um den Eröffnungs-Explorer zu nutzen (Lichess erfordert dafür jetzt eine Anmeldung) und um Studien aus deinem Konto zu importieren. Deine Blitz-Wertung wird außerdem verwendet, um die Züge im Explorer besser an dein Niveau anzupassen."
          }
        }
      }
    },
    "Sign out of \"%@\"": {
      "comment": "A button that signs out of Lichess. The argument is the user's name on Lichess.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Von \"%@\" abmelden"
          }
        }
      }
    },
    "Signing in is free and uses Lichess's official login — OpeningsMastermind never sees your password. You can sign out at any time in Settings.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Anmeldung ist kostenlos und nutzt den offiziellen Login von Lichess – OpeningsMastermind sieht dein Passwort nie. Du kannst dich jederzeit in den Einstellungen abmelden."
          }
        }
      }
    },
    "Sorting options": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sortieroptionen"
          }
        }
      }
